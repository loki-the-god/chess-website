        "postcss": "^8.5.8",
        "postcss-cli": "^11.0.1",
        "postcss-preset-env": "^11.2.0",
        "serve": "^14.2.6",
        "tailwindcss": "^4.2.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/loki-the-god/chess-website.git"
    }
