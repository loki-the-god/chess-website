    "version": "1.0.0",
    "description": "A website to play chess against my engine",
    "license": "MIT",
    "author": "",
    "type": "module",
    "main": "main.js",
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "styles": "postcss style/input.css -o style/style.css",
