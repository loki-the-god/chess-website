{
    "name": "chessweb",
    "version": "1.0.0",
    "description": "A website to play chess against my engine",
    "license": "MIT",
    "author": "",
    "type": "module",
    "main": "main.js",
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "styles": "npx @tailwindcss/cli -i ./style/input.css -o ./style/style.css",
        "dev": "npx @tailwindcss/cli -i ./style/input.css -o ./style/style.css --watch",
        "start": "npm run styles && npx serve"
    },
    "private": true,
    "devDependencies": {
        "@html-eslint/eslint-plugin": "^0.58.1",
        "@tailwindcss/cli": "^4.2.0",
        "eslint": "^10.0.3",
        "postcss": "^8.5.8",
        "postcss-cli": "^11.0.1",
        "tailwindcss": "^4.2.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/loki-the-god/chess-website.git"
    }
}
